# ~/.config/starship.toml — managed by mac-deploy
# Template: configs/templates/starship/starship.toml.tmpl
# Regenerate: bash scripts/apply-configs.sh
#
# Docs: https://starship.rs/config/

# ── Format ────────────────────────────────────────────────────────────────────

format = """
[$username@$hostname](bold blue) $directory$git_branch$git_status$cmd_duration
$character"""

add_newline = true

# ── Character ─────────────────────────────────────────────────────────────────

[character]
success_symbol = "[❯](bold green)"
error_symbol   = "[❯](bold red)"

# ── Directory ─────────────────────────────────────────────────────────────────

[directory]
truncation_length    = 3
truncate_to_repo     = true
style                = "bold cyan"

# ── Git ───────────────────────────────────────────────────────────────────────

[git_branch]
format = "[$symbol$branch]($style) "
symbol = " "
style  = "bold purple"

[git_status]
format    = '([$all_status$ahead_behind]($style) )'
style     = "bold yellow"
conflicted = "⚡"
ahead      = "⇡${count}"
behind     = "⇣${count}"
diverged   = "⇕⇡${ahead_count}⇣${behind_count}"
untracked  = "?"
modified   = "!"
staged     = "+"
deleted    = "✘"

# ── Command duration ──────────────────────────────────────────────────────────

[cmd_duration]
min_time = 2000
format   = "[ $duration]($style) "
style    = "bold yellow"

# ── Host ──────────────────────────────────────────────────────────────────────

[hostname]
ssh_only = false
format   = "[$hostname]($style)"
style    = "bold blue"
trim_at  = "."

[username]
show_always = false
format      = "[$user]($style)"
style_user  = "bold blue"
